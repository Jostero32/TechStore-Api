# ===== Copiar a .env y completar (en Render se ponen como Environment Variables) =====
# Supabase: Settings -> Database -> Connection string (URI, modo Session/pooler sirve para la API)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Réplica completa Aiven PostgreSQL: usada como FALLBACK automático si Supabase
# no responde en 3s (ver db.py / config.py). Service URI -> Aiven console -> Overview.
DATABASE_URL_REPLICA=postgresql://avnadmin:PASSWORD@pg-xxx.aivencloud.com:12345/defaultdb?sslmode=require

# Identificador de esta instancia (RENDER-1 o RENDER-2) para demostrar el balanceo
INSTANCE_NAME=RENDER-1

# Firebase Admin SDK: Configuración del proyecto -> Cuentas de servicio -> Generar clave privada
# Pegar el JSON COMPLETO en una sola línea
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# URL del servicio SOAP de facturación
SOAP_URL=https://techstore-soap.onrender.com/soap

# Twilio (SaaS de alertas)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token
TWILIO_FROM=+14155238886
TWILIO_ADMIN_PHONE=+593xxxxxxxxx

# Brevo HTTP API (sin restricción de IP — recomendado para Render)
# Brevo → SMTP & API → API Keys → Generar nueva clave
BREVO_API_KEY=tu_api_key_de_brevo
# Correo remitente verificado en Brevo → Senders & Domains
BREVO_FROM=tu_correo@dominio.com

# Alternativa SMTP genérica (Gmail, Outlook, etc. - usar contraseña de aplicación)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
SMTP_FROM=tu_correo@gmail.com
